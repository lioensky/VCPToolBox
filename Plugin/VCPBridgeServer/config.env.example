# VCPBridgeServer - local loopback prompt-injection proxy
# Copy this file to config.env only when you intentionally want to enable it.

# Default is disabled so adding the plugin does not open a new listening port.
BRIDGE_ENABLED=false

# Loopback-only bind host. Public binds are intentionally rejected by the plugin.
BRIDGE_BIND_HOST=127.0.0.1
BRIDGE_PORT=3100

# Upstream API base URL and protocol.
# Leave BRIDGE_UPSTREAM_URL empty to forward to the local VCP main server:
# http://127.0.0.1:${PORT}
# Set this only when forwarding directly to an external API provider.
BRIDGE_UPSTREAM_URL=
BRIDGE_UPSTREAM_TYPE=chat

# Optional upstream key. When BRIDGE_UPSTREAM_URL is empty, the bridge uses the
# main server Key if available. External upstream URLs require an explicit
# BRIDGE_UPSTREAM_KEY or the caller's protocol-specific auth header.
BRIDGE_UPSTREAM_KEY=

# Default model and optional alias mapping.
BRIDGE_MODEL=gpt-4.1-mini
BRIDGE_MODEL_MAP=

# Prompt text or a .txt filename located in this plugin directory.
BRIDGE_SYSTEM_PROMPT=

# Modes: off, replace, prepend, append.
BRIDGE_HIJACK_MODE=off

# Upstream request timeout.
BRIDGE_UPSTREAM_TIMEOUT_MS=120000

# Codex OAuth provider split example:
# Enable VCP_RESPONSES_PROVIDER=codex_oauth on the VCPToolBox main service.
# Keep this bridge as a pure Responses proxy to the main service; it does not
# fetch, refresh, store, or select OAuth credentials.
#
# BRIDGE_ENABLED=true
# BRIDGE_BIND_HOST=127.0.0.1
# BRIDGE_PORT=3100
# BRIDGE_UPSTREAM_URL=
# BRIDGE_UPSTREAM_TYPE=responses
# BRIDGE_MODEL=gpt-5.3-codex
# BRIDGE_HIJACK_MODE=append
# BRIDGE_SYSTEM_PROMPT=your_rules.txt
# BRIDGE_CLIENT_KEY=<REDACTED_CLIENT_KEY>
