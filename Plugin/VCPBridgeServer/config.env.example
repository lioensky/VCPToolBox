# VCPBridgeServer - local loopback prompt-injection proxy
# Copy this file to config.env only when you intentionally want to enable it.

# Default is disabled so adding the plugin does not open a new listening port.
BRIDGE_ENABLED=false

# Optional preset. Use codex-vcp-memory to route Codex model requests through
# the local VCPToolBox main service with strict memory policy prompt append.
BRIDGE_PROFILE=

# Loopback-only bind host. Public binds are intentionally rejected by the plugin.
BRIDGE_BIND_HOST=127.0.0.1
BRIDGE_PORT=3100

# Upstream API base URL and protocol.
# Leave BRIDGE_UPSTREAM_URL empty to forward to the local VCP main server:
# http://127.0.0.1:${PORT}
# Set this only when forwarding directly to an external API provider.
BRIDGE_UPSTREAM_URL=
BRIDGE_UPSTREAM_TYPE=chat

# When true, VCP-specific profiles should fail closed if a safe VCP upstream
# cannot be established. Phase 1A records the setting; later phases add doctor
# and stricter startup checks.
BRIDGE_REQUIRE_VCP_UPSTREAM=false

# Optional upstream key. When BRIDGE_UPSTREAM_URL is empty, the bridge uses the
# main server Key if available. External upstream URLs require an explicit
# BRIDGE_UPSTREAM_KEY or the caller's protocol-specific auth header.
BRIDGE_UPSTREAM_KEY=

# Optional client key for Codex -> VCPBridgeServer. Leave empty for local
# development without bridge-level client auth.
BRIDGE_CLIENT_KEY=

# Default model and optional alias mapping.
BRIDGE_MODEL=gpt-4.1-mini
BRIDGE_MODEL_MAP=

# Prompt text or a .txt filename located in this plugin directory.
# The codex-vcp-memory profile defaults this to:
# prompts/codex_vcp_memory.strict.txt
# Other explicit memory prompt choices:
# prompts/codex_vcp_memory.balanced.txt
# prompts/codex_vcp_memory.aggressive.txt
BRIDGE_SYSTEM_PROMPT=

# Modes: off, replace, prepend, append.
BRIDGE_HIJACK_MODE=off

# Browser-origin, rate-limit, and body-size guards.
BRIDGE_DENY_BROWSER_ORIGIN=true
BRIDGE_RATE_LIMIT_RPM=60
BRIDGE_MAX_BODY_MB=20

# Upstream request timeouts. The legacy timeout remains as a compatibility
# fallback; the split timeouts are preferred.
BRIDGE_UPSTREAM_TIMEOUT_MS=120000
BRIDGE_UPSTREAM_CONNECT_TIMEOUT_MS=15000
BRIDGE_UPSTREAM_TOTAL_TIMEOUT_MS=0
BRIDGE_UPSTREAM_IDLE_TIMEOUT_MS=180000

# Codex + VCPToolBox Memory Gateway example:
#
# BRIDGE_ENABLED=true
# BRIDGE_PROFILE=codex-vcp-memory
# BRIDGE_BIND_HOST=127.0.0.1
# BRIDGE_PORT=3100
# BRIDGE_UPSTREAM_URL=
# BRIDGE_UPSTREAM_TYPE=chat
# BRIDGE_HIJACK_MODE=append
# BRIDGE_SYSTEM_PROMPT=prompts/codex_vcp_memory.strict.txt
# BRIDGE_REQUIRE_VCP_UPSTREAM=true
# BRIDGE_CLIENT_KEY=<REDACTED_CLIENT_KEY>
