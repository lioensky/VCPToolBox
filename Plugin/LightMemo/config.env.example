# LightMemoPlugin Configuration

# 需要屏蔽、任何时候都不搜索的日记文件夹名称，用逗号分隔。
# 例如: EXCLUDED_FOLDERS=已整理,夜伽,MusicDiary,SomeOtherFolder
EXCLUDED_FOLDERS=已整理,夜伽,MusicDiary

# Rerank 功能所需的 API 配置
# 如果您不打算使用 Rerank 功能，可以留空。
RerankUrl=
RerankApi=
RerankModel=
RerankMaxTokensPerBatch=30000

# AIMemo+ 无需在 LightMemo 中重复配置。
# 当工具参数 aimemo=true 或 aimemo_preset=预设名 时，
# LightMemo 会通过 AIMemoBridge 复用 Plugin/RAGDiaryPlugin/config.env 中的
# AIMemoModel、AIMemoUrl、AIMemoApi、AIMemoPrompt、缓存及 MoreAIMemoPresets。