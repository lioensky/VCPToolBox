# LightMemo Configuration
#
# 生产检索构型由工具参数选择：
# - rivermemo：Rust/Rayon Topology V3（默认）
# - tagmemo：标准 TagMemo V9
# - knn：向量/BM25 混合检索
# TagMemoAB 会在同一权限候选域中比较 KNN、TagMemo V9、Rust V3，
# 并默认尝试增加独立 Rerank 轨道。本文件不再包含任何 V10 实验配置。

# 需要屏蔽、任何时候都不搜索的日记文件夹名称，用逗号分隔。
# 例如: EXCLUDED_FOLDERS=已整理,夜伽,MusicDiary,SomeOtherFolder
EXCLUDED_FOLDERS=已整理,夜伽,MusicDiary

# 外部 Rerank 服务。留空时普通检索跳过 Rerank；
# TagMemoAB 的 Rerank 轨道会明确标记为不可用。
RerankUrl=
RerankApi=
RerankModel=

# 单次最多提交 25 个候选，代码硬上限为 25。
# 普通记忆、TDB 冷知识检索和 TagMemoAB 共用这些批处理限制。
RerankMaxDocumentsPerRequest=25

# 小批量请求最大并发数，代码限制范围为 1~10。
RerankMaxConcurrentRequests=3

# 候选数或估算 Token 任一达到限制时即拆分批次。
RerankMaxTokensPerBatch=30000

# AIMemo+ 无需在 LightMemo 中重复配置。
# aimemo=true 或 aimemo_preset=预设名时，通过 AIMemoBridge 复用
# Plugin/RAGDiaryPlugin/config.env 中的模型、API、提示词、缓存及预设。