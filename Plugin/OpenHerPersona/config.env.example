# OpenHerPersona 插件配置模板
# 仅在需要本地覆盖配置时复制为 config.env。

# 启用插件逻辑。为 false 时，status/explain 仍可工作，但消息 hint 与 tick 状态变更会被禁用。
OpenHerPersonaEnabled=true

# 启用通过 processMessages 注入简短 persona_state_hint。
# 为 false 时，插件仍会根据消息更新每个 Agent 的本地状态，但不会影响模型提示词。
OpenHerPersonaHintEnabled=true

# 仅观察模式：保留每个 Agent 的情绪统计与状态持久化，但永不注入 persona_state_hint。
# 适用于仪表盘/审计，或模型行为必须保持不变的试运行场景。
OpenHerPersonaObserveOnly=false

# 启用手动 tick 状态变更。无论如何，MVP 都不会主动发送消息。
OpenHerPersonaTickEnabled=true

# tick 审计使用的冷却时间窗口。
OpenHerPersonaCooldownMinutes=240

# 相对冲动阈值。值会按 Number 解析；默认值为 0.8。
OpenHerPersonaImpulseThreshold=0.8

# 每个 Agent 的气质差异幅度（0 - 0.4）。值越大，不同 Agent 的人格分化越明显；
# 设为 0 时，所有 Agent 共享中性画像。
OpenHerPersonaTemperamentSpread=0.13

# 语义上下文感知。优先在 requiresContextBridge 可用时使用 RAGDiaryPlugin ContextBridge
# 的嵌入缓存/清洗器，然后回退到宿主嵌入 API（API_URL/API_Key + WhitelistEmbeddingModel），
# 用于把 8 个上下文特征与锚点短语进行评分，并与关键词启发式结果混合。
# 当嵌入服务不可用、超时或报错时，会静默回退到启发式逻辑。
OpenHerPersonaSemanticContext=true

# 语义分数的混合权重（0 = 仅启发式，1 = 仅语义）。
OpenHerPersonaSemanticWeight=0.5

# 情绪相位跃迁（strained -> eruption -> cooling）。当持续热度、安全感受挫、
# 以及痛苦级别 persona_delta 事件产生的压力跨过阈值时，
# Agent 会真正爆发一个回合，然后进入冷却。
OpenHerPersonaPhaseEnabled=true

# 两次爆发之间的最小间隔分钟数；若压力在冷却期间跨过阈值，
# 状态会停留在“strained”上限，而不会进入爆发。
OpenHerPersonaEruptionCooldownMinutes=90

# 聊天气泡模式。当表达引擎处于健谈/情绪状态时，hint 会要求模型把单次回复拆成
# 2-5 条短 IM 风格消息，并用 brk 注释标记分隔；VCPChat 会在流式输出过程中
# 实时渲染为独立气泡。不会产生额外模型调用。该 hint 仅在请求可明确证明来自
# VCPChat（vcpchatExtensions 载荷，或类似 VCPChat/VChat 的 OneRing 客户端标签）
# 时发出；未知客户端永远不会收到这些标记。
OpenHerPersonaBurstEnabled=true

# 气泡触发模式：auto = 情绪门控（默认），always = 每个回合都携带拆分指令
#（模型仍会保持技术内容不拆分），off = 关闭。
OpenHerPersonaBurstMode=auto

# HTML 表达 hint。与气泡模式配合，告诉模型可以在表达性时刻使用轻量级行内样式
# HTML 片段（小卡片、强调色、简单布局），也可放在气泡内。与气泡模式一样严格限定
# 仅 VCPChat 可用；禁止 script 标签或外部资源。
OpenHerPersonaHtmlHintEnabled=true

# 标准 VCP 调试标志。
DebugMode=false
