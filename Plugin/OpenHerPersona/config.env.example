# OpenHerPersona plugin configuration template
# Copy to config.env only if local overrides are needed.

# Enable plugin logic. When false, status/explain still work but message hint and tick mutation are disabled.
OpenHerPersonaEnabled=true

# Enable short persona_state_hint injection via processMessages.
OpenHerPersonaHintEnabled=true

# Enable manual tick state mutation. MVP never sends proactive messages either way.
OpenHerPersonaTickEnabled=true

# Cooldown window used by tick audit.
OpenHerPersonaCooldownMinutes=240

# Relative impulse threshold. Values are parsed as Number; default is 0.8.
OpenHerPersonaImpulseThreshold=0.8

# Per-agent temperament spread (0 - 0.4). Larger values make different agents'
# personalities diverge more strongly; 0 makes every agent share the neutral profile.
OpenHerPersonaTemperamentSpread=0.13

# Semantic context sensing. Uses the host's embedding API (API_URL/API_Key +
# WhitelistEmbeddingModel) to score the 8 context features against anchor phrases,
# blended with the keyword heuristic. Silently falls back to the heuristic when
# the embedding service is unavailable, times out, or errors.
OpenHerPersonaSemanticContext=true

# Blend weight of the semantic score (0 = heuristic only, 1 = semantic only).
OpenHerPersonaSemanticWeight=0.5

# Emotional phase transition (strained -> eruption -> cooling). When pressure from
# sustained heat, safety hits, and distress-tier persona_delta events crosses the
# threshold, the agent genuinely erupts for one turn, then cools down.
OpenHerPersonaPhaseEnabled=true

# Minimum minutes between eruptions; pressure crossing the threshold during the
# cooldown stays capped at "strained" instead.
OpenHerPersonaEruptionCooldownMinutes=90

# Chat-burst mode. When the expression engine is in a chatty/emotional state, the
# hint asks the model to split its single reply into 2-5 short IM-style messages
# separated by brk comment markers; VCPChat renders them as separate bubbles in
# real time during streaming. Zero extra model calls. The hint is ONLY issued when
# the request is provably from VCPChat (vcpchatExtensions payload or a OneRing
# client label like VCPChat/VChat); unknown clients never receive markers.
OpenHerPersonaBurstEnabled=true

# Burst trigger mode: auto = emotion-gated (default), always = every turn carries
# the split instruction (the model still keeps technical content unsplit), off.
OpenHerPersonaBurstMode=auto

# HTML expression hint. Alongside burst mode, tells the model it may use light
# inline-styled HTML snippets (small cards, accent colors, simple layout) for
# expressive moments, optionally inside burst bubbles. Same strict VCPChat-only
# gating as burst mode; no script tags or external resources.
OpenHerPersonaHtmlHintEnabled=true

# Standard VCP debug flag.
DebugMode=false
