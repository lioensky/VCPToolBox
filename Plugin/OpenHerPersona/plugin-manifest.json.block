{
  "manifestVersion": "1.0.0",
  "name": "OpenHerPersona",
  "version": "0.5.1",
  "displayName": "OpenHer Persona Bridge",
  "description": "VCP-native persona-state bridge inspired by OpenHer drives/signals. Keeps lightweight homeostatic drive state, per-agent temperament genomes and metabolic constitutions with slow plasticity, mood-inertia behavior signals, an emotional phase-transition machine (strained/eruption/cooling), expression-driven chat-burst hinting (split replies into IM-style bubbles via brk comment markers, no extra model calls), short persona_state_hint preprocessing, observe-only statistics mode without prompt injection, and direct status/tick/reset/explain commands without proactive sending or long-term memory writes.",
  "author": "Nova",
  "pluginType": "hybridservice",
  "entryPoint": {
    "type": "nodejs",
    "script": "OpenHerPersona.js"
  },
  "communication": {
    "protocol": "direct",
    "timeout": 30000
  },
  "requiresContextBridge": true,
  "configSchema": {
    "DebugMode": "boolean",
    "OpenHerPersonaEnabled": "boolean",
    "OpenHerPersonaHintEnabled": "boolean",
    "OpenHerPersonaObserveOnly": "boolean",
    "OpenHerPersonaTickEnabled": "boolean",
    "OpenHerPersonaCooldownMinutes": "integer",
    "OpenHerPersonaImpulseThreshold": "string",
    "OpenHerPersonaTemperamentSpread": "string",
    "OpenHerPersonaSemanticContext": "boolean",
    "OpenHerPersonaSemanticWeight": "string",
    "OpenHerPersonaPhaseEnabled": "boolean",
    "OpenHerPersonaEruptionCooldownMinutes": "integer",
    "OpenHerPersonaBurstEnabled": "boolean",
    "OpenHerPersonaBurstMode": "string",
    "OpenHerPersonaHtmlHintEnabled": "boolean"
  },
  "capabilities": {
    "invocationCommands": [
      {
        "command": "status",
        "description": "Return current OpenHerPersona MVP state, configuration flags, and safety boundaries. Does not call an LLM or write memory.\n- `command`: fixed as `status`.",
        "example": "<<<[TOOL_REQUEST]>>>\ntool_name: 「始」OpenHerPersona「末」,\ncommand: 「始」status「末」\n<<<[END_TOOL_REQUEST]>>>"
      },
      {
        "command": "tick",
        "description": "Run a local drive-metabolism tick and return an impulse audit. MVP never sends proactive messages and never calls an LLM.\n- `command`: fixed as `tick`.\n- `reason`: optional audit note.",
        "example": "<<<[TOOL_REQUEST]>>>\ntool_name: 「始」OpenHerPersona「末」,\ncommand: 「始」tick「末」,\nreason: 「始」manual smoke「末」\n<<<[END_TOOL_REQUEST]>>>"
      },
      {
        "command": "reset",
        "description": "Reset local persona state to MVP defaults. Does not delete long-term VCP memory.\n- `command`: fixed as `reset`.",
        "example": "<<<[TOOL_REQUEST]>>>\ntool_name: 「始」OpenHerPersona「末」,\ncommand: 「始」reset「末」\n<<<[END_TOOL_REQUEST]>>>"
      },
      {
        "command": "explain",
        "description": "Explain OpenHerPersona architecture boundaries and how OpenHer concepts map onto VCP-native infrastructure.\n- `command`: fixed as `explain`.",
        "example": "<<<[TOOL_REQUEST]>>>\ntool_name: 「始」OpenHerPersona「末」,\ncommand: 「始」explain「末」\n<<<[END_TOOL_REQUEST]>>>"
      }
    ]
  }
}
