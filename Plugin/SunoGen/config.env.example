# 基础信息，用于调用suno模型
SunoKey="your key"
# Suno API 基础 URL (可选, 如果您的服务商不同，请修改此项)
SunoApiBaseUrl="https://api.sunoapi.org"
# docs.sunoapi.org 新协议要求 callback URL
SunoCallbackUrl="https://your-server.example.com/suno/callback"
# 轮询间隔（毫秒），默认 5000
# SunoPollingIntervalMs="5000"
# 最大轮询次数，默认 60
# SunoMaxPollingAttempts="60"


