# VCPFeishu 插件环境配置示例
# 复制为 config.env 后填写。模型、VCP 地址、API Key、上下文参数均从
# VCPChat/AppData/settings.json 与绑定 Agent 的 config.json 获取，不在插件里重复配置。

# 飞书自建应用凭证（必填）
FeishuAppId=cli_xxxxxxxxxxxx
FeishuAppSecret=xxxxxxxxxxxxxxxxxxxxxxxx

# 绑定的 VCPChat Agent（必填）
# 支持 Agent 目录名、id、name 或 chineseName
FeishuBindAgent=记忆大师

# 回复策略（可选）
# true = 先回复提示语，再回复完整 AI 内容
FeishuStreamReply=true
FeishuStreamHint=正在思考中…

# 白名单（可选）
# 留空 = 不限制；填写 open_id 逗号分隔 = 仅这些用户可触发
# FeishuAllowedUsers=ou_xxxxx,ou_yyyyy

# 调试日志（可选）
DebugMode=false
