{
  "manifestVersion": "1.0.0",
  "name": "MediaToolBox",
  "version": "1.0.0",
  "displayName": "多媒体工具箱",
  "description": "该收纳箱收纳了各种多媒体处理，图片生成，视频生成和编辑，音乐生成相关的工具，用于动态向 Agent 提供说明。",
  "author": "System",
  "pluginType": "static",
  "entryPoint": {
    "type": "nodejs",
    "command": "node toolbox-fold.js"
  },
  "communication": {
    "protocol": "stdio",
    "timeout": 15000
  },
  "capabilities": {
    "systemPromptPlaceholders": [
      {
        "placeholder": "{{VCPMediaToolBox}}",
        "description": "基于上下文相关性动态展开或折叠的 VCP 多媒体工具箱说明文档集合。"
      }
    ]
  },
  "refreshIntervalCron": "*/5 * * * *"
}