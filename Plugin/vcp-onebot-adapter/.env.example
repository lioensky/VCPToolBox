# VCP OneBot Adapter 配置
# 支持 go-cqhttp, NapCat, LLOneBot 等 OneBot 11 协议实现

# ============ OneBot 连接配置 ============
# OneBot WebSocket 正向连接地址 (go-cqhttp/NapCat 的 ws 地址)
ONEBOT_WS_URL=ws://127.0.0.1:3001

# 或者使用反向 WebSocket (让 OneBot 连接到本适配器)
# ONEBOT_REVERSE_WS_PORT=3002

# access_token (如果 OneBot 配置了)
ONEBOT_ACCESS_TOKEN=

# ============ VCP ChannelHub 配置 ============
# VCP ChannelHub B2 协议地址
VCP_CHANNEL_HUB_URL=http://127.0.0.1:6010/internal/channel-hub/events

# 适配器 ID (在 ChannelHub 中注册的唯一标识)
VCP_ADAPTER_ID=onebot-qq-main

# ChannelHub 桥接密钥
VCP_CHANNEL_BRIDGE_KEY=your-bridge-key-here

# ============ Agent 配置 ============
# 默认 Agent 名称
VCP_AGENT_NAME=Nova
VCP_AGENT_DISPLAY_NAME=Nova

# ============ QQ 平台能力配置 ============
# 是否支持图片发送
ONEBOT_SUPPORTS_IMAGE=true
# 是否支持文件发送
ONEBOT_SUPPORTS_FILE=false
# 是否支持语音发送
ONEBOT_SUPPORTS_AUDIO=true
# 最大消息长度 (QQ 群消息约 4500 字)
ONEBOT_MAX_MESSAGE_LENGTH=4500

# ============ 日志配置 ============
LOG_LEVEL=info

# ============ 高级配置 ============
# 消息重试次数
MESSAGE_RETRY_COUNT=3
# 重试间隔 (毫秒)
MESSAGE_RETRY_INTERVAL=1000
# 会话超时时间 (小时)
SESSION_TIMEOUT_HOURS=24
