# Semicolon-separated roots that Agent-created attachments may reference.
# Relative paths are resolved from the VCPToolBox project root.
# When unset, the plugin defaults to the project-local file directory.
ALLOWED_ATTACHMENT_ROOTS=file

# Maximum single attachment size in bytes. Default: 50 MiB.
MAX_ATTACHMENT_BYTES=52428800

# Index location. The plugin stores metadata here, not large file payloads.
ATTACHMENT_CACHE_DIR=.file_cache/agent_attachments

# Hash algorithm used to verify the source did not change before download.
ATTACHMENT_HASH_ALGORITHM=sha256

# Unknown extensions become application/octet-stream when true.
ALLOW_UNKNOWN_MIME=true

# Attachment metadata TTL.
ATTACHMENT_TTL_SECONDS=86400

# Optional absolute public base URL. Empty returns relative /v1/attachments/:id.
ATTACHMENT_DOWNLOAD_BASE_URL=

# Download auth. When key is empty, the plugin falls back to global Key.
SERVER_ATTACHMENT_REQUIRE_AUTH=true
SERVER_ATTACHMENT_KEY=
