# Optional SkillBridge overrides for deterministic local generation.
# Copy to config.env only when you want plugin-local behavior to win over ambient env.

# Shared repos should prefer relative paths so regenerated indexes stay portable.
SKILLBRIDGE_PATH_MODE=relative

# Fold threshold for each skill block in the generated index.
SKILLBRIDGE_DEFAULT_THRESHOLD=0.35

# Optional custom header text.
# SKILLBRIDGE_HEADER_TEXT=这里是Skill技能目录，若你需要对应技能，请使用文件管理插件的Ink模式读取技能。
