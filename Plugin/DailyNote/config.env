# Daily Note File Extension
# Supported values: "txt", "md"
DAILY_NOTE_EXTENSION=txt


# Fuzzy Diff for Update Failures
# When update fails to find exact match, return diff info between AI target and best matching diary segment
# Supported values: "true", "false"
DAILY_NOTE_FUZZY_DIFF=true

# let ai help tag gen
TagMaster=false
TagModel=claude-4-8-opus
TagModelMaxOutPutTokens=30000
TagModelMaxTokens=40000
TagModelPrompt=TagMaster.txt