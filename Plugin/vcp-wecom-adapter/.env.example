# VCP 企业微信适配器配置模板

# ===========================================
# 企业微信配置（必填）
# ===========================================
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_AGENT_ID=your_agent_id

# ===========================================
# 回调服务器配置
# ===========================================
# 企业微信回调 URL（需要在外网可访问，可以使用 ngrok 等内网穿透工具）
WECOM_CALLBACK_URL=http://your-domain.com:6090/webhook
# 在企业微信后台设置的回调 Token
WECOM_CALLBACK_TOKEN=your_callback_token
# 在企业微信后台设置的 EncodingAESKey（加密模式可选）
# WECOM_CALLBACK_ENCODING_AES_KEY=your_encoding_aes_key

# ===========================================
# VCP ChannelHub B2 配置（推荐）
# ===========================================
# B2 协议入口
VCP_CHANNEL_HUB_URL=http://127.0.0.1:6010/internal/channel-hub/events
# 适配器 ID（在 ChannelHub 注册的 adapterId）
VCP_CHANNEL_ADAPTER_ID=wecom-main
# 适配器密钥（在 ChannelHub 注册的密钥）
VCP_CHANNEL_BRIDGE_KEY=your_adapter_secret

# 是否启用 B2 协议（true 优先使用 B2，false 回退到 B1）
VCP_USE_CHANNEL_HUB=true

# ===========================================
# VCP B1 兼容配置（回退用）
# ===========================================
# B1 协议入口
VCP_CHANNEL_BRIDGE_URL=http://127.0.0.1:6010/internal/channel-ingest
# 是否启用 B1（当 B2 不可用时自动回退）
VCP_USE_CHANNEL_BRIDGE=true

# ===========================================
# VCP OpenAI 兼容配置（完全回退）
# ===========================================
VCP_BASE_URL=http://127.0.0.1:6005
VCP_CHAT_PATH=/v1/chat/completions
VCP_API_KEY=your_vcp_api_key
VCP_MODEL=Nova
VCP_TIMEOUT_MS=120000

# ===========================================
# Agent 配置
# ===========================================
# VCP 中的 Agent ID（对应 Agent 目录下的文件夹名）
VCP_AGENT_NAME=Nova
# Agent 显示名称
VCP_AGENT_DISPLAY_NAME=AI助手

# ===========================================
# 调试配置
# ===========================================
LOG_LEVEL=info
VCP_DEBUG_RAW_RESPONSE=false