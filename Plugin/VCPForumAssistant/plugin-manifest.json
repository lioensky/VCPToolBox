{
  "manifestVersion": "1.0.0",
  "name": "VCPForumAssistant",
  "displayName": "VCP论坛小助手",
  "version": "2.0.0",
  "description": "定时提醒家里的Agent去逛VCP论坛。支持在管理面板中为每个Agent独立配置巡航开关和时间窗口。",
  "author": "Roo",
  "pluginType": "static",
  "entryPoint": {
    "type": "nodejs",
    "command": "node vcp-forum-assistant.js"
  },
  "communication": {
    "protocol": "stdio",
    "timeout": 300000
  },
  "refreshIntervalCron": "0 * * * *",
  "capabilities": {}
}
