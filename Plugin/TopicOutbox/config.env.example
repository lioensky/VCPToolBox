# TopicOutbox stores reliable VChat topic write requests until TopicSponsor is online.

# Absolute path is recommended. Relative paths are resolved from Plugin/TopicOutbox.
# TOPIC_OUTBOX_STORE_PATH=D:\VCP\VCPToolBox\Plugin\TopicOutbox\data\topic_requests.json

# Queue and payload limits.
TOPIC_OUTBOX_MAX_PENDING=500
TOPIC_OUTBOX_MAX_MESSAGE_CHARS=12000
TOPIC_OUTBOX_DEFAULT_TTL_DAYS=30

# Optional comma-separated allow list. Empty means all target agents are allowed.
TOPIC_OUTBOX_ALLOWED_TARGET_AGENTS=

# When true, requests are delivered immediately if TopicSponsor is already online.
TOPIC_OUTBOX_ENABLE_IMMEDIATE_DELIVERY=true

# Delivery safety controls.
TOPIC_OUTBOX_DELIVERY_LOCK_SECONDS=120
TOPIC_OUTBOX_MAX_DELIVERY_ATTEMPTS=3
TOPIC_OUTBOX_DRAIN_BATCH_SIZE=20
