# 必填：ClawEmail API Key
# 注意：这不是 npx @clawemail/claw-setup --auth-url 后面的临时 URL。
# auth-url 只用于官方一键安装/授权流程；这里需要最终可供 SDK 使用的 API Key。
ClawMailKey=

# 必填：需要管理/轮询的 ClawEmail 邮箱，多个用英文逗号分隔。
# 第一个邮箱会作为默认邮箱，除非显式设置 ClawMailDefaultUser。
ClawMailUsers=bot@claw.163.com

# 可选：默认读取/发件邮箱。
ClawMailDefaultUser=bot@claw.163.com

# 可选：常驻轮询间隔，毫秒。默认 60000。
ClawMailPollIntervalMs=60000

# 可选：每个邮箱缓存最近邮件数量。默认 20。
ClawMailPollLimit=20

# 可选：read_mail 未传 markRead 时是否默认标记已读。默认 false。
ClawMailAutoMarkRead=false

# 可选：调试日志。
DebugMode=false
