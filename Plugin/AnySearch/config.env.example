# AnySearch API Key is optional. Anonymous access works with lower limits.
# To obtain a key: https://anysearch.com/settings/api-keys
ANYSEARCH_API_KEY=

# Optional JSON-RPC endpoint override.
ANYSEARCH_ENDPOINT=https://api.anysearch.com/mcp

# Optional HTTP timeout in milliseconds, clamped to 1000-120000.
ANYSEARCH_TIMEOUT_MS=30000
